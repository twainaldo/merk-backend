# ====================
# SERVEUR
# ====================
PORT=3000

# ====================
# WORKERS
# ====================
# Nombre de scrapers en parallèle (10-20 pour 1000 comptes)
WORKER_CONCURRENCY=10

# ====================
# PROXIES
# ====================
# Activer/désactiver les proxies rotatifs (true/false)
USE_PROXIES=true

# ====================
# CRON JOBS
# ====================
# Timezone pour les scraping automatiques
TIMEZONE=Europe/Paris

# Format cron: minute heure * * *
# Rapport matin (défaut: 9h00)
CRON_MORNING=0 9 * * *

# Rapport soir (défaut: 21h00)
CRON_EVENING=0 21 * * *

# ====================
# SCRAPING
# ====================
# Timeout par scraping (en millisecondes)
SCRAPING_TIMEOUT=60000

# Délai entre chaque retry (en millisecondes)
RETRY_DELAY=5000

# Nombre de tentatives par compte
RETRY_ATTEMPTS=3
